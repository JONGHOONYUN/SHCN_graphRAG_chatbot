# Streamlit secrets template — copy to `.streamlit/secrets.toml` and fill in
# real values. The real file must NEVER be committed (see .gitignore).
#
# All keys below are read by the app. Fields marked (required) are checked at
# import time; the app will refuse to start without them. Fields marked
# (optional) fall back to safe defaults documented alongside each entry.

# ── Access control ─────────────────────────────────────────────────────────
# Shared tester password. Compared with hmac.compare_digest (constant-time).
# Rate limiting is deliberately NOT implemented in the app — apply it at the
# deployment layer (Streamlit Cloud, reverse proxy, or an IP throttle).
APP_PASSWORD = "replace-me"


# ── Google Gemini ──────────────────────────────────────────────────────────
GOOGLE_API_KEY = "replace-me"          # (required)

# Chat model. Any current Gemini chat model — e.g. "models/gemini-2.5-flash",
# "models/gemini-1.5-pro". Consumed by ChatGoogleGenerativeAI in llm.py.
GOOGLE_MODEL = "replace-me"            # (required)

# Embedding model. Pinned in llm.py — auto-discovery is disabled in the
# request path (Phase 5 hardening). Recommended: "models/gemini-embedding-001"
# which produces 3072-dim vectors and matches the existing Neo4j indexes
# (EntryTextsKor / EntryTextsEng / EntryTextsChi).
GOOGLE_EMBEDDING_MODEL = "models/gemini-embedding-001"   # (optional; safe default)

# Optional dimension pin. When set, every embedding response is checked for
# an exact length match. Detects silent server-side model swaps that would
# otherwise poison the vector index. Leave unset to let the first successful
# response pin the dimension for the process.
EMBEDDING_DIMENSION = 3072             # (optional)


# ── Neo4j Aura ─────────────────────────────────────────────────────────────
# IMPORTANT — application-layer Cypher validation (tools/cypher_safety.py)
# blocks writes on the LLM path, but the Neo4j account used here should ALSO
# be a read-only role. Chat history stored under `Neo4jChatMessageHistory`
# will need write access; either use TWO accounts (read-only for chains,
# writer for history) or scope the account with fine-grained roles.
NEO4J_URI      = "neo4j+s://replace-me"
NEO4J_USERNAME = "read-only-user"
NEO4J_PASSWORD = "replace-me"
NEO4J_DATABASE = "neo4j"


# ── Authority-lookup caps (all optional) ───────────────────────────────────
# Bounded caps for external-authority enrichment. Defaults defined in
# tools/orchestrator.py; override here per environment.
# AUTHORITY_PERSON_CAP         = 10
# AUTHORITY_PLACE_CAP          = 5
# AUTHORITY_SOURCES_PER_ENTITY = 2
